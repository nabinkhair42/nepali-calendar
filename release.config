# Single source of truth for app-identity constants.
#
# Sourced as a shell file by:
#   - app/build.sh
#   - app/release.sh
#
# The Swift side mirrors these in app/Sources/NepaliCalendar/AppConstants.swift
# and the web side in web/src/lib/app-constants.ts. If you change a value here,
# update those two as well — they read the same things at compile time and
# can't `source` shell.
#
# Per-release values (version, build, sha256) are NOT here — those live in
# app/Info.plist (version + build) and are computed by release.sh (sha256).
# release.sh then propagates them into web/public/downloads/latest.json and
# patches web/public/install.sh in place.

# Bundle/folder name. Used for the .app folder, binary, DMG, and bundle ID.
APP_NAME="NepaliCalendar"

# Human-facing name. Shown in the menu bar, DMG volume label, installer
# messages, Info.plist CFBundleDisplayName.
APP_DISPLAY="Nepali Calendar"

# macOS bundle identifier. Must match Info.plist CFBundleIdentifier exactly.
APP_BUNDLE_ID="app.nabinkhair.NepaliCalendar"

# Public website hostname (no scheme). Owns /downloads/, /install.sh,
# /api/app/update, /changelog, and the main marketing page.
WEBSITE_HOST="calendar.nabinkhair.com.np"

# GitHub repo in owner/name form. Used for release URLs and gh CLI calls.
GITHUB_REPO="nabinkhair42/nepali-calendar"

# Derived — set once here so callers don't reassemble.
DMG_FILENAME="${APP_NAME}.dmg"
DOWNLOAD_URL="https://${WEBSITE_HOST}/downloads/${DMG_FILENAME}"
MANIFEST_URL="https://${WEBSITE_HOST}/downloads/latest.json"
UPDATE_API_URL="https://${WEBSITE_HOST}/api/app/update"
GITHUB_RELEASES_URL="https://github.com/${GITHUB_REPO}/releases"
